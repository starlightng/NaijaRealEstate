# Required — change these before running
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/realestate_db

# Optional overrides
DEBUG=true
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=["http://localhost:3001"]

# Email — fill in when ready
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@realestate.local
